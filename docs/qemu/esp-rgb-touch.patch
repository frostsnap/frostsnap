+static int esp_rgb_scale_abs_axis(int value, int max_out)
+{
+    return qemu_input_scale_axis(value,
+                                 INPUT_EVENT_ABS_MIN,
+                                 INPUT_EVENT_ABS_MAX,
+                                 0,
+                                 max_out);
+}
+
+static void esp_rgb_queue_touch(ESPRgbState *s, int x, int y, bool pressed,
+                                uint32_t action)
+{
+    if (s->width == 0 || s->height == 0) {
+        return;
+    }
+
+    x = MAX(0, MIN(x, (int) s->width - 1));
+    y = MAX(0, MIN(y, (int) s->height - 1));
+
+    s->touch_x = x;
+    s->touch_y = y;
+    s->touch_pos = (x << 16) | (y & 0xffff);
+    s->touch_state = RGB_TOUCH_PENDING
+                   | (pressed ? RGB_TOUCH_PRESSED : 0)
+                   | ((action << RGB_TOUCH_ACTION_SHIFT) & RGB_TOUCH_ACTION_MASK);
+}
+
+static void esp_rgb_mouse_event(DeviceState *dev, QemuConsole *src,
+                                InputEvent *evt)
+{
+    ESPRgbState *s = ESP_RGB(dev);
+    InputBtnEvent *btn;
+    InputMoveEvent *move;
+    int x = s->touch_x;
+    int y = s->touch_y;
+
+    switch (evt->type) {
+    case INPUT_EVENT_KIND_BTN:
+        btn = evt->u.btn.data;
+        if (btn->button == INPUT_BUTTON_LEFT || btn->button == INPUT_BUTTON_TOUCH) {
+            s->touch_pressed = btn->down;
+            esp_rgb_queue_touch(s, x, y, s->touch_pressed,
+                                s->touch_pressed ? RGB_TOUCH_ACTION_DOWN
+                                                 : RGB_TOUCH_ACTION_UP);
+        }
+        break;
+    case INPUT_EVENT_KIND_ABS:
+        move = evt->u.abs.data;
+        if (move->axis == INPUT_AXIS_X) {
+            x = esp_rgb_scale_abs_axis(move->value, s->width - 1);
+        } else if (move->axis == INPUT_AXIS_Y) {
+            y = esp_rgb_scale_abs_axis(move->value, s->height - 1);
+        }
+        if (s->touch_pressed) {
+            esp_rgb_queue_touch(s, x, y, true, RGB_TOUCH_ACTION_MOVE);
+        } else {
+            s->touch_x = x;
+            s->touch_y = y;
+            s->touch_pos = (x << 16) | (y & 0xffff);
+        }
+        break;
+    default:
+        break;
+    }
+}
+
+static const QemuInputHandler esp_rgb_mouse_handler = {
+    .name = "ESP RGB Touch",
+    .mask = INPUT_EVENT_MASK_BTN | INPUT_EVENT_MASK_ABS,
+    .event = esp_rgb_mouse_event,
+};
